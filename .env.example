# Copiez ce fichier vers .env.local pour tester Stripe en local.
# Ne mettez jamais de cle secrete Stripe dans le code source.

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_remplacez_moi
STRIPE_SECRET_KEY=sk_test_remplacez_moi
ADMIN_MODE=true

# Stats vues/favoris. En local, sans base, un JSON temporaire non versionne
# est utilise. En production Vercel, ajoutez une vraie base Postgres.
# PRODUCT_STATS_DATABASE_URL=postgres://...
# ou DATABASE_URL=postgres://...
# ou POSTGRES_URL=postgres://...

# A utiliser plus tard pour valider les evenements Stripe cote serveur.
STRIPE_WEBHOOK_SECRET=whsec_remplacez_moi_plus_tard
