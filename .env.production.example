# Exemple de variables a definir chez l'hebergeur de production.
# Ne jamais commiter de fichier .env.production contenant de vraies cles.

NEXT_PUBLIC_SITE_URL=https://maxitrouvaille.fr

# Stripe reste volontairement en mode test pour le moment.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_remplacez_moi
STRIPE_SECRET_KEY=sk_test_remplacez_moi

# A renseigner plus tard quand le webhook Stripe sera active.
STRIPE_WEBHOOK_SECRET=whsec_remplacez_moi_plus_tard

# Pour la premiere mise en ligne publique, garder l'admin cache.
# Remettre true seulement sur une version protegee par authentification.
ADMIN_MODE=false

# Base de donnees pour les vues/favoris reels en production.
# Recommande : Postgres fourni par Vercel/Neon/Supabase.
# Une seule de ces variables suffit, selon le fournisseur :
# PRODUCT_STATS_DATABASE_URL=postgres://...
# DATABASE_URL=postgres://...
# POSTGRES_URL=postgres://...

# Plus tard, quand tu valideras le passage en paiement reel :
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_SECRET_KEY=sk_live_...
